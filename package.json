{
  "name": "codex-mobile-monorepo",
  "private": true,
  "scripts": {
    "dev:mobile": "turbo run dev --filter=@codex-mobile/mobile",
    "dev:desktop": "turbo run tauri:dev --filter=@codex-mobile/desktop",
