{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Whats Coder",
  "version": "0.1.0",
  "identifier": "com.whats-coder.desktop",
  "build": {
    "beforeDevCommand": "pnpm --dir .. dev",
    "devUrl": "http://localhost:6188",
    "beforeBuildCommand": "pnpm --dir .. build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Whats Coder",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ws://localhost:* http://localhost:*; img-src 'self' data: blob: asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
